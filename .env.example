# Redis connection
REDIS_ADDR=redis:6379          # host:port of the Redis server
REDIS_PASSWORD=                # leave empty if no auth
REDIS_DB=0                     # Redis logical DB index (0-15)

# Producer HTTP server
PRODUCER_PORT=8081             # port the producer listens on

# Dashboard HTTP server
DASHBOARD_PORT=8080            # port the dashboard listens on
DASHBOARD_USER=admin           # basic auth username
DASHBOARD_PASSWORD=admin       # basic auth password — change this in prod

# Consumer worker pool
CONSUMER_WORKERS=5             # number of parallel XREADGROUP goroutines
CONSUMER_NAME=worker-1         # base name; workers append -0, -1, ... suffix

# Logging
LOG_LEVEL=info                 # debug | info | warn | error